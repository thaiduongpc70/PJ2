<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard | Dự Đoán Chi Phí Y Tế</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        medical: {
                            blue: '#0A58CA',
                            navy: '#04419A',
                            cyan: '#0EA5E9',
                            mint: '#10B981',
                            soft: '#EEF4FC',
                            danger: '#DC3545'
                        }
                    }
                }
            }
        }
    </script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/assets/css/admin.css">
</head>

<body class="bg-medical-soft text-slate-800">
    <div class="min-h-screen flex">
        <aside class="admin-sidebar w-72 bg-gradient-to-b from-medical-blue to-medical-navy text-white hidden lg:flex flex-col">
            <div class="p-6 border-b border-white/10">
                <div class="flex items-center gap-3">
                    <div class="w-12 h-12 rounded-2xl bg-white/15 flex items-center justify-center">
                        <i class="fa-solid fa-user-shield text-2xl"></i>
                    </div>

                    <div>
                        <h1 class="text-xl font-extrabold">Admin Y Tế</h1>
                        <p class="text-blue-100 text-sm">Healthcare Control</p>
                    </div>
                </div>
            </div>

            <nav class="p-4 space-y-2 flex-1">
                <button class="admin-tab active-tab" data-tab="dashboard">
                    <i class="fa-solid fa-chart-line"></i>
                    Dashboard
                </button>

                <button class="admin-tab" data-tab="predictions">
                    <i class="fa-solid fa-database"></i>
                    Kết quả dự đoán
                </button>

                <button class="admin-tab" data-tab="users">
                    <i class="fa-solid fa-users-gear"></i>
                    Người dùng
                </button>

                <button class="admin-tab" data-tab="logs">
                    <i class="fa-solid fa-clock-rotate-left"></i>
                    Nhật ký hệ thống
                </button>
            </nav>

            <div class="sidebar-actions p-4 border-t border-white/10 space-y-3">
                <a href="/" class="w-full flex items-center justify-center gap-2 rounded-xl bg-white text-medical-blue font-bold py-3 hover:bg-blue-50 transition">
                    <i class="fa-solid fa-house-medical"></i>
                    Về trang chính
                </a>

                <button onclick="logout()" class="w-full flex items-center justify-center gap-2 rounded-xl bg-red-500/90 text-white font-bold py-3 hover:bg-red-500 transition">
                    <i class="fa-solid fa-right-from-bracket"></i>
                    Đăng xuất
                </button>
            </div>
        </aside>

        <main class="flex-1">
            <header class="bg-white shadow-sm border-b border-blue-100 sticky top-0 z-20">
                <div class="px-5 lg:px-8 py-4 flex items-center justify-between">
                    <div>
                        <p class="text-sm uppercase tracking-widest text-medical-blue font-bold">Hệ thống quản trị</p>
                        <h2 class="text-2xl font-extrabold text-slate-900" id="page-title">Dashboard</h2>
                    </div>

                    <div class="flex items-center gap-3">
                        <a href="/" class="hidden sm:inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-blue-50 text-medical-blue font-bold hover:bg-blue-100">
                            <i class="fa-solid fa-arrow-left"></i>
                            Trang chính
                        </a>

                        <div class="px-4 py-2 rounded-xl bg-slate-100">
                            <p class="text-xs text-slate-500">Admin</p>
                            <p class="font-bold" id="admin-name">...</p>
                        </div>
                    </div>
                </div>
            </header>

            <div class="admin-mobile-nav lg:hidden">
                <button class="admin-tab active-tab" data-tab="dashboard">
                    <i class="fa-solid fa-chart-line"></i>
                    Dashboard
                </button>

                <button class="admin-tab" data-tab="predictions">
                    <i class="fa-solid fa-database"></i>
                    Dự đoán
                </button>

                <button class="admin-tab" data-tab="users">
                    <i class="fa-solid fa-users-gear"></i>
                    User
                </button>

                <button class="admin-tab" data-tab="logs">
                    <i class="fa-solid fa-clock-rotate-left"></i>
                    Logs
                </button>
            </div>

            <div class="admin-mobile-actions lg:hidden">
                <a href="/" class="admin-mobile-action-home">
                    <i class="fa-solid fa-house-medical"></i>
                    Trang chính
                </a>

                <button type="button" onclick="logout()" class="admin-mobile-action-logout">
                    <i class="fa-solid fa-right-from-bracket"></i>
                    Đăng xuất
                </button>
            </div>

            <section class="p-5 lg:p-8">
                <div id="admin-alert" class="hidden mb-5 rounded-2xl px-5 py-4 font-semibold"></div>

                <section id="tab-dashboard" class="admin-section">
                    <div id="dashboard-stats-wrap" class="collapsed-block mb-6">
                        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-5">
                            <div class="stat-card" data-open-tab="users">
                                <div>
                                    <p class="stat-label">Tổng người dùng</p>
                                    <h3 class="stat-number" id="stat-users">0</h3>
                                    <p class="stat-hint">Bấm để xem người dùng</p>
                                </div>
                                <i class="fa-solid fa-users text-medical-blue text-3xl"></i>
                            </div>

                            <div class="stat-card" data-open-tab="predictions">
                                <div>
                                    <p class="stat-label">Tổng dự đoán</p>
                                    <h3 class="stat-number" id="stat-predictions">0</h3>
                                    <p class="stat-hint">Bấm để xem dự đoán</p>
                                </div>
                                <i class="fa-solid fa-file-medical text-medical-mint text-3xl"></i>
                            </div>

                            <div class="stat-card" data-open-tab="predictions">
                                <div>
                                    <p class="stat-label">Dự đoán hôm nay</p>
                                    <h3 class="stat-number" id="stat-today">0</h3>
                                    <p class="stat-hint">Bấm để xem lịch sử</p>
                                </div>
                                <i class="fa-solid fa-calendar-day text-medical-cyan text-3xl"></i>
                            </div>

                            <div class="stat-card" data-open-tab="predictions">
                                <div>
                                    <p class="stat-label">Chi phí TB</p>
                                    <h3 class="stat-number text-medical-danger" id="stat-avg">$0</h3>
                                    <p class="stat-hint">Bấm để xem dự đoán</p>
                                </div>
                                <i class="fa-solid fa-dollar-sign text-medical-danger text-3xl"></i>
                            </div>

                            <div class="stat-card" data-open-tab="users">
                                <div>
                                    <p class="stat-label">Admin</p>
                                    <h3 class="stat-number" id="stat-admins">0</h3>
                                    <p class="stat-hint">Bấm để quản lý user</p>
                                </div>
                                <i class="fa-solid fa-user-shield text-medical-blue text-3xl"></i>
                            </div>

                            <div class="stat-card" data-open-tab="users">
                                <div>
                                    <p class="stat-label">Staff</p>
                                    <h3 class="stat-number" id="stat-staff">0</h3>
                                    <p class="stat-hint">Bấm để quản lý user</p>
                                </div>
                                <i class="fa-solid fa-user-nurse text-medical-cyan text-3xl"></i>
                            </div>

                            <div class="stat-card" data-open-tab="users">
                                <div>
                                    <p class="stat-label">Member</p>
                                    <h3 class="stat-number" id="stat-members">0</h3>
                                    <p class="stat-hint">Bấm để quản lý user</p>
                                </div>
                                <i class="fa-solid fa-user text-medical-mint text-3xl"></i>
                            </div>

                            <div class="stat-card" data-open-tab="logs">
                                <div>
                                    <p class="stat-label">Admin actions</p>
                                    <h3 class="stat-number" id="stat-admin-actions">0</h3>
                                    <p class="stat-hint">Bấm để xem nhật ký</p>
                                </div>
                                <i class="fa-solid fa-clipboard-list text-medical-danger text-3xl"></i>
                            </div>

                            <div class="stat-card" data-open-tab="predictions">
                                <div>
                                    <p class="stat-label">Chi phí thấp nhất</p>
                                    <h3 class="stat-number text-medical-mint" id="stat-min-cost">$0</h3>
                                    <p class="stat-hint">Bấm để xem dự đoán</p>
                                </div>
                                <i class="fa-solid fa-arrow-trend-down text-medical-mint text-3xl"></i>
                            </div>

                            <div class="stat-card" data-open-tab="predictions">
                                <div>
                                    <p class="stat-label">Chi phí cao nhất</p>
                                    <h3 class="stat-number text-medical-danger" id="stat-max-cost">$0</h3>
                                    <p class="stat-hint">Bấm để xem dự đoán</p>
                                </div>
                                <i class="fa-solid fa-arrow-trend-up text-medical-danger text-3xl"></i>
                            </div>

                            <div class="stat-card" data-open-tab="logs">
                                <div>
                                    <p class="stat-label">Feedback</p>
                                    <h3 class="stat-number" id="stat-feedback">0</h3>
                                    <p class="stat-hint">Bấm để xem nhật ký</p>
                                </div>
                                <i class="fa-solid fa-comments text-medical-blue text-3xl"></i>
                            </div>

                            <div class="stat-card" data-open-tab="logs">
                                <div>
                                    <p class="stat-label">Activity logs</p>
                                    <h3 class="stat-number" id="stat-activity-logs">0</h3>
                                    <p class="stat-hint">Bấm để xem nhật ký</p>
                                </div>
                                <i class="fa-solid fa-clock-rotate-left text-medical-cyan text-3xl"></i>
                            </div>
                        </div>
                    </div>

                    <div class="mb-6 text-center">
                        <button type="button" class="see-more-btn" data-target="dashboard-stats-wrap">
                            <i class="fa-solid fa-chevron-down"></i>
                            Xem thêm thống kê
                        </button>
                    </div>

                    <div class="grid grid-cols-1 xl:grid-cols-2 gap-6 mb-6">
                        <div class="panel-card">
                            <div class="panel-header">
                                <h3>Thống kê theo mô hình</h3>
                                <button class="mini-btn" onclick="loadStatsByModel()">Làm mới</button>
                            </div>
                            <div id="stats-model-table" class="limited-table"></div>
                        </div>

                        <div class="panel-card">
                            <div class="panel-header">
                                <h3>Thống kê theo vùng</h3>
                                <button class="mini-btn" onclick="loadStatsByRegion()">Làm mới</button>
                            </div>
                            <div id="stats-region-table" class="limited-table"></div>
                        </div>
                    </div>

                    <div class="panel-card">
                        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4 mb-5">
                            <div>
                                <h3 class="text-xl font-extrabold text-slate-900">Thống kê theo ngày</h3>
                                <p class="text-slate-500 text-sm">Theo dõi số lượng dự đoán và chi phí trung bình theo từng ngày.</p>
                            </div>

                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                                <input id="date-stat-from" type="date" class="admin-input">
                                <input id="date-stat-to" type="date" class="admin-input">
                            </div>

                            <button class="primary-btn" onclick="loadStatsByDate()">
                                <i class="fa-solid fa-chart-simple"></i>
                                Xem thống kê
                            </button>
                        </div>

                        <div id="stats-date-table" class="limited-table"></div>
                    </div>
                </section>

                <section id="tab-predictions" class="admin-section hidden">
                    <div class="panel-card">
                        <div class="flex flex-col xl:flex-row xl:items-end xl:justify-between gap-4 mb-5">
                            <div>
                                <h3 class="text-xl font-extrabold">Quản lý kết quả dự đoán</h3>
                                <p class="text-slate-500 text-sm">Xem, lọc và xóa thật kết quả dự đoán.</p>
                            </div>

                            <div class="grid grid-cols-1 sm:grid-cols-4 gap-3">
                                <input id="filter-user-id" type="number" placeholder="User ID" class="admin-input">
                                <select id="filter-model-id" class="admin-input">
                                    <option value="">Tất cả model</option>
                                    <option value="1">Basic</option>
                                    <option value="2">Advanced</option>
                                </select>
                                <input id="filter-date-from" type="date" class="admin-input">
                                <input id="filter-date-to" type="date" class="admin-input">
                            </div>

                            <div class="flex gap-2">
                                <button class="primary-btn" onclick="loadPredictions()">
                                    <i class="fa-solid fa-filter"></i>
                                    Lọc
                                </button>

                                <button class="danger-btn" onclick="deleteAllPredictions()">
                                    <i class="fa-solid fa-trash-can"></i>
                                    Xóa tất cả
                                </button>
                            </div>
                        </div>

                        <div id="predictions-table" class="limited-table-large"></div>
                    </div>
                </section>

                <section id="tab-users" class="admin-section hidden">
                    <div class="panel-card">
                        <div class="flex flex-col xl:flex-row xl:items-end xl:justify-between gap-4 mb-5">
                            <div>
                                <h3 class="text-xl font-extrabold">Quản lý người dùng</h3>
                                <p class="text-slate-500 text-sm">Khóa/mở tài khoản và phân quyền.</p>
                            </div>

                            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                                <input id="filter-keyword" type="text" placeholder="Username hoặc email" class="admin-input">
                                <select id="filter-role" class="admin-input">
                                    <option value="">Tất cả role</option>
                                    <option value="admin">Admin</option>
                                    <option value="staff">Staff</option>
                                    <option value="member">Member</option>
                                </select>
                                <select id="filter-status" class="admin-input">
                                    <option value="">Tất cả trạng thái</option>
                                    <option value="active">Active</option>
                                    <option value="disabled">Disabled</option>
                                    <option value="pending">Pending</option>
                                </select>
                            </div>

                            <button class="primary-btn" onclick="loadUsers()">
                                <i class="fa-solid fa-magnifying-glass"></i>
                                Tìm kiếm
                            </button>
                        </div>

                        <div id="users-table" class="limited-table-large"></div>
                    </div>
                </section>

                <section id="tab-logs" class="admin-section hidden">
                    <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
                        <div class="panel-card">
                            <div class="panel-header">
                                <h3>Activity Logs</h3>
                                <button class="mini-btn" onclick="loadActivityLogs()">Làm mới</button>
                            </div>
                            <div id="activity-logs-table" class="limited-table-large"></div>
                        </div>

                        <div class="panel-card">
                            <div class="panel-header">
                                <h3>Admin Actions</h3>
                                <button class="mini-btn" onclick="loadAdminActions()">Làm mới</button>
                            </div>
                            <div id="admin-actions-table" class="limited-table-large"></div>
                        </div>
                    </div>
                </section>
            </section>
        </main>
    </div>

    <script src="/assets/js/api_client.js"></script>
    <script src="/assets/js/admin.js"></script>
</body>
</html>