<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Chọn Phương Pháp Dự Đoán</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        medical: {
                            blue: '#0A58CA',
                            navy: '#04419A',
                            cyan: '#0EA5E9',
                            mint: '#10B981',
                            soft: '#EEF4FC',
                            danger: '#DC3545',
                            ink: '#0F172A'
                        }
                    },
                    boxShadow: {
                        medical: '0 18px 45px rgba(10, 88, 202, 0.12)',
                        soft: '0 10px 30px rgba(15, 23, 42, 0.08)'
                    }
                }
            }
        }
    </script>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/assets/css/select_method.css">
</head>

<body class="min-h-screen bg-medical-soft text-slate-800">
    <nav class="navbar-custom sticky top-0 z-40">
        <div class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-4 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
            <a class="navbar-brand group flex items-center gap-3" href="/">
                <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-blue-50 text-medical-blue ring-1 ring-blue-100 transition group-hover:bg-medical-blue group-hover:text-white">
                    <i class="fa-solid fa-hospital-user text-xl"></i>
                </span>

                <span class="leading-tight">
                    <span class="block text-lg font-black text-medical-blue sm:text-xl">Hệ Thống Dự Đoán Y Tế</span>
                    <span class="hidden text-xs font-bold uppercase tracking-[0.22em] text-slate-400 sm:block">AI Prediction Method</span>
                </span>
            </a>

            <div class="flex flex-wrap items-center gap-3">
                <a href="/" class="btn btn-outline-primary">
                    <i class="fa-solid fa-arrow-left"></i>
                    Quay lại Trang chủ
                </a>

                <div id="auth-nav-container" class="flex items-center gap-3"></div>
            </div>
        </div>
    </nav>

    <main class="mx-auto max-w-7xl px-4 pb-16 pt-8 sm:px-6 lg:px-8">
        <section class="hero-section">
            <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-white/10 blur-2xl"></div>
            <div class="absolute -bottom-24 left-1/3 h-72 w-72 rounded-full bg-cyan-300/20 blur-3xl"></div>

            <div class="relative mx-auto max-w-4xl text-center">
                <p class="mb-4 inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-2 text-xs font-black uppercase tracking-[0.22em] text-blue-100 ring-1 ring-white/20">
                    <i class="fa-solid fa-layer-group"></i>
                    Lựa chọn mô hình AI
                </p>

                <h1 class="hero-title">
                    Chọn phương pháp<br>
                    <span class="text-blue-100">dự đoán chi phí y tế</span>
                </h1>

                <p class="mx-auto mt-5 max-w-3xl text-base leading-8 text-blue-50 sm:text-lg">
                    Vui lòng chọn 1 trong 2 phương pháp dưới đây tùy thuộc vào mức độ chi tiết của hồ sơ y tế mà bạn đang có.
                </p>
            </div>
        </section>

        <section class="-mt-12 grid gap-6 lg:grid-cols-2 lg:px-8">
            <article class="method-card group" onclick="window.location.href='/basic'">
                <div class="method-badge bg-cyan-50 text-medical-cyan ring-cyan-100">
                    <i class="fa-solid fa-bolt"></i>
                    Nhanh gọn
                </div>

                <div class="icon-box bg-cyan-50 text-medical-cyan">
                    <i class="fa-solid fa-bolt"></i>
                </div>

                <div class="mt-6 text-center">
                    <h2 class="text-3xl font-black tracking-tight text-slate-900">Dự Đoán Cơ Bản</h2>
                    <p class="mt-2 text-lg font-black text-medical-blue">18 Chỉ số Đầu vào</p>

                    <p class="mx-auto mt-4 max-w-md leading-7 text-slate-500">
                        Sử dụng thuật toán tối ưu để dự đoán nhanh dựa trên các sinh hiệu cơ bản và thông tin nhân khẩu học. Phù hợp khi bạn không nắm rõ tiền sử bệnh lý phức tạp.
                    </p>
                </div>

                <ul class="method-list">
                    <li>
                        <i class="fa-solid fa-check"></i>
                        Tuổi, Giới tính, Khu vực
                    </li>

                    <li>
                        <i class="fa-solid fa-check"></i>
                        Chiều cao, Cân nặng, BMI
                    </li>

                    <li>
                        <i class="fa-solid fa-check"></i>
                        Hút thuốc / Rượu bia
                    </li>

                    <li>
                        <i class="fa-solid fa-check"></i>
                        Các chỉ số cơ bản
                    </li>
                </ul>

                <a href="/basic" class="btn btn-outline-info mt-6 w-full rounded-full" onclick="event.stopPropagation();">
                    <i class="fa-solid fa-arrow-right"></i>
                    Chọn Mô Hình Này
                </a>
            </article>

            <article class="method-card method-card-featured group" onclick="window.location.href='/advanced'">
                <div class="method-badge bg-red-50 text-medical-danger ring-red-100">
                    <i class="fa-solid fa-star"></i>
                    Chuyên sâu
                </div>

                <div class="icon-box bg-blue-50 text-medical-blue">
                    <i class="fa-solid fa-microscope"></i>
                </div>

                <div class="mt-6 text-center">
                    <h2 class="text-3xl font-black tracking-tight text-slate-900">Dự Đoán Chuyên Sâu</h2>
                    <p class="mt-2 text-lg font-black text-medical-danger">Đầy đủ 24 Chỉ số</p>

                    <p class="mx-auto mt-4 max-w-md leading-7 text-slate-500">
                        Sử dụng toàn bộ sức mạnh của Machine Learning với 24 biến số y tế, tiền sử bệnh và lối sống. Cung cấp độ chính xác cao nhất mà mô hình có thể đạt được.
                    </p>
                </div>

                <ul class="method-list">
                    <li>
                        <i class="fa-solid fa-check"></i>
                        Mọi chỉ số của bản Cơ bản
                    </li>

                    <li>
                        <i class="fa-solid fa-check"></i>
                        Nhóm máu, Nhiệt độ
                    </li>

                    <li>
                        <i class="fa-solid fa-check"></i>
                        Tiền sử bệnh nền
                    </li>

                    <li>
                        <i class="fa-solid fa-check"></i>
                        Nhịp tim, Đường huyết, Stress
                    </li>
                </ul>

                <a href="/advanced" class="btn btn-primary mt-6 w-full rounded-full" onclick="event.stopPropagation();">
                    <i class="fa-solid fa-arrow-right"></i>
                    Chọn Mô Hình Này
                </a>
            </article>
        </section>

        <section class="mt-10 grid gap-5 rounded-3xl border border-blue-100 bg-white/80 p-5 shadow-soft backdrop-blur md:grid-cols-3">
            <div class="info-card">
                <i class="fa-solid fa-shield-halved text-medical-mint"></i>
                <div>
                    <h3>Dữ liệu bảo mật</h3>
                    <p>Thông tin y tế được xử lý qua API nội bộ của hệ thống.</p>
                </div>
            </div>

            <div class="info-card">
                <i class="fa-solid fa-database text-medical-blue"></i>
                <div>
                    <h3>Lưu lịch sử</h3>
                    <p>Kết quả dự đoán được ghi vào lịch sử cá nhân để dễ theo dõi.</p>
                </div>
            </div>

            <div class="info-card">
                <i class="fa-solid fa-chart-line text-medical-danger"></i>
                <div>
                    <h3>So sánh mô hình</h3>
                    <p>Có thể chọn nhanh hoặc chuyên sâu tùy dữ liệu bạn có.</p>
                </div>
            </div>
        </section>
    </main>

    <footer class="mt-10 bg-slate-950 text-white">
        <div class="mx-auto grid max-w-7xl gap-8 px-4 py-12 sm:px-6 md:grid-cols-[1.3fr_0.7fr] lg:px-8">
            <div>
                <h5 class="mb-5 text-lg font-black uppercase tracking-wider text-blue-200">Hệ thống Dự đoán Y Tế</h5>
                <div class="space-y-3 text-slate-300">
                    <p><i class="fa-solid fa-building mr-2 text-blue-300"></i> <strong>Trụ sở chính:</strong> Khu Công nghệ cao, Q. Cầu Giấy, Hà Nội</p>
                    <p><i class="fa-solid fa-envelope mr-2 text-blue-300"></i> <strong>Email:</strong> trungtamdudoan@yte.vn</p>
                    <p><i class="fa-solid fa-phone-flip mr-2 text-blue-300"></i> <strong>Hotline 24/7:</strong> 1900 1508 (Miễn phí cước)</p>
                </div>
            </div>

            <div class="text-left md:text-right">
                <h5 class="mb-5 text-lg font-black uppercase tracking-wider text-blue-200">Địa chỉ</h5>

                <button type="button" class="map-thumbnail group relative inline-block h-40 w-full max-w-sm overflow-hidden rounded-3xl border border-slate-700 bg-slate-900 shadow-xl" data-bs-toggle="modal" data-bs-target="#mapModal">
                    <span class="absolute inset-0 bg-gradient-to-br from-blue-600/30 to-cyan-400/10"></span>
                    <span class="absolute left-1/2 top-1/2 flex -translate-x-1/2 -translate-y-1/2 flex-col items-center gap-3 text-slate-200 transition group-hover:scale-105">
                        <i class="fa-solid fa-map-location-dot text-4xl"></i>
                        <span class="text-sm font-bold">Xem bản đồ</span>
                    </span>
                </button>
            </div>
        </div>
    </footer>

    <div class="modal fade" id="mapModal" tabindex="-1" aria-labelledby="mapModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-dark text-white border-bottom border-secondary">
                    <h5 class="modal-title" id="mapModalLabel">
                        <i class="fa-solid fa-map-location-dot me-2"></i>
                        Bản đồ định vị - Hà Nội
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body p-0">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3723.863855881387!2d105.74685977598835!3d21.038132787458145!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3134559863c0a525%3A0x2ce8b1e0f06ec1ba!2sHoa%20Lac%20Hi-Tech%20Park!5e0!3m2!1sen!2s!4v1700000000000!5m2!1sen!2s"
                        width="100%" height="500" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="accountModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content overflow-hidden rounded-3xl">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold">
                        <i class="fas fa-user-cog me-2"></i>
                        Quản lý Tài Khoản
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <form id="change-password-form">
                    <div class="modal-body p-4">
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted">Tên đăng nhập</label>
                            <input type="text" id="modal-username-display" class="form-control bg-light" disabled>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Mật khẩu hiện tại</label>
                            <input type="password" name="old_password" class="form-control" required placeholder="Nhập mật khẩu cũ...">
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Mật khẩu mới</label>
                            <input type="password" name="new_password" class="form-control" required placeholder="Nhập mật khẩu mới...">
                        </div>
                    </div>

                    <div class="modal-footer bg-light">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                        <button type="submit" class="btn btn-success">Xác nhận đổi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/assets/js/api_client.js"></script>
    <script src="/assets/js/main.js"></script>

</body>
</html>